import json
import os
import streamlit as st

# Nome do arquivo onde os orçamentos ficarão guardados
ARQUIVO_BANCO = "orcamentos.json"


# --- FUNÇÕES DE MANIPULAÇÃO DE DADOS ---
def carregar_banco():
    """Lê o arquivo JSON e retorna os orçamentos salvos."""
    if os.path.exists(ARQUIVO_BANCO):
        with open(ARQUIVO_BANCO, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def salvar_no_banco(numero_orcamento, dados_orcamento):
    """Salva ou atualiza um orçamento no arquivo JSON."""
    banco = carregar_banco()
    # Forçamos o número a ser uma string para evitar problemas no JSON
    banco[str(numero_orcamento)] = dados_orcamento
    with open(ARQUIVO_BANCO, "w", encoding="utf-8") as f:
        json.dump(banco, f, indent=4, ensure_ascii=False)


# --- INICIALIZAÇÃO DO ESTADO DA TELA (SESSION STATE) ---
# Precisamos disso para que o Streamlit consiga preencher os campos dinamicamente
if "num_orcamento" not in st.session_state:
    st.session_state.num_orcamento = ""
if "nome_cliente" not in st.session_state:
    st.session_state.nome_cliente = ""
if "observacoes" not in st.session_state:
    st.session_state.observacoes = ""

# --- INTERFACE CORPO DO APP ---
st.title("Sistema de Orçamentos")

# 1. SEÇÃO DE BUSCA (Fica no topo)
st.subheader("🔍 Buscar Orçamento")
col_busca, col_btn_busca = st.columns([3, 1])

with col_busca:
    numero_busca = st.text_input(
        "Digite o número do orçamento para editar", key="input_busca"
    )

with col_btn_busca:
    st.write("")  # Só para alinhar o botão verticalmente
    if st.button("Buscar", use_container_width=True):
        banco = carregar_banco()

        if numero_busca in banco:
            dados = banco[numero_busca]
            # Alimenta as variáveis da tela com os dados guardados
            st.session_state.num_orcamento = numero_busca
            st.session_state.nome_cliente = dados["cliente"]
            st.session_state.observacoes = dados["observacoes"]
            st.success(f"Orçamento nº {numero_busca} carregado com sucesso!")
            st.rerun()  # Recarrega a página para atualizar os campos visuais
        else:
            st.error("Orçamento não encontrado.")

st.divider()

# 2. CAMPOS DO ORÇAMENTO (Onde você digita)
st.subheader("✍️ Dados do Orçamento")

# IMPORTANTE: Usamos o parâmetro 'key' apontando para as variáveis do session_state
num_orcamento = st.text_input("Número do Orçamento", key="num_orcamento")
nome_cliente = st.text_input("Nome do Cliente", key="nome_cliente")
observacoes = st.text_area("Observações", key="observacoes")

# 3. BOTÃO DE SALVAR / ATUALIZAR
if st.button("Salvar Orçamento", type="primary"):
    if not num_orcamento:
        st.error("Por favor, insira um número para o orçamento.")
    else:
        # Monta a caixinha de dados que vai pro arquivo JSON
        dados_para_salvar = {
            "cliente": nome_cliente,
            "observacoes": observacoes,
            # Se você tiver uma lista de produtos/itens, você adicionaria aqui também
        }

        salvar_no_banco(num_orcamento, dados_para_salvar)
        st.success(
            f"Orçamento nº {num_orcamento} salvo/atualizado com sucesso!"
        )
